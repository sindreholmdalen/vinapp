APP_NAME=VinApp
APP_ENV=production
APP_KEY=                       # Genereres av Forge automatisk
APP_DEBUG=false
APP_URL=https://ditt-domene.no

LOG_CHANNEL=stack
LOG_LEVEL=error

# Database (MySQL via Forge)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vinapp
DB_USERNAME=forge
DB_PASSWORD=                      Settes av Forge

# Cache & Sessions via database (stabilt for produksjon)
BROADCAST_DRIVER=log
CACHE_DRIVER=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Vinmonopolet API
VINMONOPOLET_API_URL=https://apis.vinmonopolet.no
TĒÍMONOPOLET_API_KEY=1372558460754872855d1247cc1ba33f

# Vite
VITE_APP_NAME="${APP_NAME}"

# Optional: Redis for better caching (kan aktiveres senere)
# CACHE_DRIVER=redis
# QUEUE_CONNECTION=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
